<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Fuselage (nose points up = 0 deg heading, matching track bearing convention) -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M9.3,8.7A2.7,2.7 0 0,1 14.7,8.7L14.7,14.3A2.7,2.7 0 0,1 9.3,14.3Z" />
    <!-- Tail boom -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M11.4,14.3L12.6,14.3L12.6,21.5L11.4,21.5Z" />
    <!-- Tail rotor -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M10,21L14,21L14,22L10,22Z" />
    <!-- Main rotor: two blades crossed in an X over the mast, mast shifted back toward the
         fuselage center (y=11, not y=9) and blades extended well past the body so they read
         clearly as spinning rotor blades rather than a single bar. -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M5.21,3.65L4.65,4.21L18.79,18.35L19.35,17.79Z" />
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M5.21,18.35L4.65,17.79L18.79,3.65L19.35,4.21Z" />
    <!-- Rotor hub, drawn on top at the mast point -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M10.9,11A1.1,1.1 0 1,0 13.1,11A1.1,1.1 0 1,0 10.9,11Z" />
</vector>
